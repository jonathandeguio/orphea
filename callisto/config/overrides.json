{
  "@jupyter-lsp/jupyterlab-lsp:completion": {
    "continuousHinting": true,
    "suppressContinuousHintingIn": [
      "Comment",
      "BlockComment",
      "LineComment",
      "String"
    ],
    "suppressTriggerCharacterIn": [
      "Comment",
      "BlockComment",
      "LineComment",
      "String"
    ],
    "waitForBusyKernel": true,
    "theme": "vscode",
    "kernelCompletionsFirst": false,
    "caseSensitive": true,
    "includePerfectMatches": true,
    "preFilterMatches": true,
    "labelExtra": "auto",
    "layout": "side-by-side",
    "typesMap": {
      "<unknown>": "Kernel",
      "instance": "Value",
      "path": "File",
      "param": "Variable",
      "missing": "Constant",
      "nothing": "Constant",
      "undefinitializer": "Constant",
      "base.devnull": "Constant"
    },
    "disable": false
  },
  "@jupyterlab/notebook-extension:tracker": {
    "codeCellConfig": {
      "lineNumbers": false,
      "lineWrap": false,
      "autoClosingBrackets": true
    },
    "markdownCellConfig": {
      "lineNumbers": false,
      "matchBrackets": false,
      "autoClosingBrackets": true
    },
    "rawCellConfig": {
      "lineNumbers": false,
      "matchBrackets": false,
      "autoClosingBrackets": true
    }
  },
  "jupyterlab-news-notifications": {
    "enabled": false
  },
  "@jupyterlab/completer-extension:manager": {
    "availableProviders": {
      "lsp": 1000,
      "CompletionProvider:context": 500,
      "CompletionProvider:kernel": 550
    },
    "providerTimeout": 1000,
    "showDocumentationPanel": true,
    "autoCompletion": true
  },
  "@jupyterlab/apputils-extension:notification": {
    "checkForUpdates": false,
    "doNotDisturbMode": true,
    "fetchNews": "none"
  }
}