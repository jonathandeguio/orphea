  "scripts": {
    "start": "(GENERATE_SOURCEMAP=false) & (set GENERATE_SOURCEMAP=false) & craco start",
    "startOld": "GENERATE_SOURCEMAP=false craco start",
    "startLocal": "REACT_APP_BASE_URL_API=http://localhost:8080/api REACT_APP_WS_URL=http://localhost:8080/api/ws yarn startOld",
    "startLocalWin": "REACT_APP_BASE_URL_API=http://localhost:8080/api REACT_APP_WS_URL=http://localhost:8080/api/ws yarn start",
    "startDemo": "(REACT_APP_BASE_URL_API=https://demo.bosler.io/api) && (REACT_APP_WS_URL=https://demo.bosler.io/api/ws) && yarn start",
    "startStaging": "REACT_APP_BASE_URL_API=https://bora.bosler.io/api REACT_APP_WS_URL=https://bora.bosler.io/api/ws yarn startOld",
    "startDev": "REACT_APP_BASE_URL_API=https://buran.bosler.io:8058/api REACT_APP_WS_URL=https://buran.bosler.io:8058/api/ws yarn startOld",
    "startProd": "REACT_APP_BASE_URL_API=https://nexus.bosler.io/api REACT_APP_WS_URL=https://nexus.bosler.io/api/ws yarn startOld",
    "starttest": "craco start",
    "build": "(set NODE_OPTIONS=--max-old-space-size=8192) & GENERATE_SOURCEMAP=false craco build",
    "prettier": "prettier --check './**/*.{js,jsx,ts,tsx,scsss,css,html,md,json}'",
    "prettier:fix": "prettier --write './**/*.{js,jsx,ts,tsx,scsss,css,html,md,json}'",
    "analyze": "yarn run build --analyze",
    "test": "craco test",
    "eject": "craco eject",
    "postinstall": "patch-package",
    "lint": "eslint './**/*.{js,jsx,ts,tsx}' --max-warnings=6",
    "lint:fix": "eslint './**/*.{js,jsx,ts,tsx}' --fix --max-warnings=6",
    "prettier-lint:fix": "npm run prettier:fix && npm run lint:fix"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
