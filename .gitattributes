
# Force LF line endings for shell scripts and files used in Docker/Linux
*.sh        text eol=lf
*.py        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.less      text eol=lf
*.scss      text eol=lf
